# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required for downloading models (Qwen2.5, camembert-ner, rebel-large, etc.)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Neo4j AuraDB (cloud — no local container needed) ──────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Project paths (defaults work inside Docker — change only if needed) ────────
PDF_PATH=documents/corpus_clean.docx
DATA_DIR=data
OUTPUT_DIR=outputs

# ── Optional flags ─────────────────────────────────────────────────────────────
# Set to "true" to wipe and reimport the Neo4j graph on startup
NEO4J_CLEAR_ON_IMPORT=false

# ── Frontend (used by docker-compose at build time) ───────────────────────────
# Must be the URL the *browser* can reach — keep localhost for local Docker use.
VITE_API_URL=http://localhost:8000
